{
  "name": "claude-wizard",
  "version": "0.3.0",
  "description": "🤖 Interactive CLI to discover, browse, and install Claude AI agents from GitHub repositories",
  "main": "src/index.js",
  "bin": {
    "claude-wizard": "./bin/claude-wizard.js"
  },
  "scripts": {
    "start": "node bin/claude-wizard.js",
    "test": "jest",
    "lint": "eslint src/ bin/",
    "lint:fix": "eslint src/ bin/ --fix",
    "build": "npm run lint && npm test",
    "dev": "node bin/claude-wizard.js",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "release:patch": "npm version patch && git push origin --tags",
    "release:minor": "npm version minor && git push origin --tags",
    "release:major": "npm version major && git push origin --tags",
    "prerelease": "npm run build"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "chalk": "^4.1.2",
    "commander": "^14.0.0",
    "fs-extra": "^11.3.1",
    "inquirer": "^8.2.7",
    "node-cache": "^5.1.2",
    "ora": "^5.4.1",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "eslint": "^9.34.0",
    "husky": "^9.1.7",
    "jest": "^30.0.5",
    "lint-staged": "^16.1.5"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "agents",
    "cli",
    "interactive",
    "github",
    "automation",
    "productivity",
    "developer-tools",
    "anthropic"
  ],
  "author": {
    "name": "Moinsen Dev",
    "email": "uli@moinsen.dev",
    "url": "https://github.com/moinsen-dev/claude-wizard"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/moinsen-dev/claude-wizard.git"
  },
  "bugs": {
    "url": "https://github.com/moinsen-dev/claude-wizard/issues"
  },
  "homepage": "https://github.com/moinsen-dev/claude-wizard#readme",
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix"
    ],
    "bin/**/*.js": [
      "eslint --fix"
    ]
  },
  "files": [
    "bin/",
    "src/",
    "config/",
    ".husky/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "CLAUDE.md"
  ],
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/templates/"
    ]
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix"
    ],
    "bin/**/*.js": [
      "eslint --fix"
    ],
    "test/**/*.js": [
      "eslint --fix"
    ]
  }
}
